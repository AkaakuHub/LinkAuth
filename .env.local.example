# 共通
ACCOUNT_URL=http://localhost:8787/ # URL文字列、auth/account WorkerのURL
DOMAIN_NAME=localhost # ドメイン文字列、CookieとCSPの基準domain
SESSION_KID=2026-04 # 文字列、account/appセッション署名key ID

# account Worker
AUTH_APPS=[{"app_id":"service","callback_url":"http://localhost:8789/_auth/callback","session_verify_secret":"same-value-as-sample-app-APP_SESSION_HMAC_SECRET"}] # JSON配列文字列、認可するapp一覧。複数appは配列へ追加します。各session_verify_secretは該当appのAPP_SESSION_HMAC_SECRETと同じ値にします

DISCORD_CLIENT_ID= # 文字列、Discord OAuth2 client ID
DISCORD_CLIENT_SECRET= # 文字列、Discord OAuth2 client secret
DISCORD_GUILD_IDS= # カンマ区切り文字列、認証対象DiscordサーバーID
DISCORD_BOT_TOKEN= # 文字列、OTP DM送信用Bot token

SESSION_HMAC_SECRET= # 文字列、accountセッション署名secret
CSRF_KID=2026-04 # 文字列、CSRF署名key ID
CSRF_HMAC_SECRET= # 文字列、CSRF署名secret
OTP_HMAC_SECRET= # 文字列、OTPハッシュ用secret

# サンプルapp Worker
APP_ID=service # 文字列、このenvから生成するapp Workerのapp ID
APP_SESSION_HMAC_SECRET= # 文字列、APP_IDに対応するappセッション署名secret。AUTH_APPSの同じapp_idのsession_verify_secretと一致させます
