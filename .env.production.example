# 共通
ACCOUNT_URL=https://account.example.com/ # URL文字列、auth/account Workerの本番URL
DOMAIN_NAME=example.com # ドメイン文字列、CookieとCSPの基準domain
SESSION_KID=2026-04 # 文字列、account/appセッション署名key ID

# Cloudflare
CLOUDFLARE_API_TOKEN= # 文字列、Terraform用Cloudflare API token
CLOUDFLARE_ACCOUNT_ID= # 文字列、Cloudflare account ID
CLOUDFLARE_ZONE_ID= # 文字列、Cloudflare zone ID
CLOUDFLARE_ACCOUNT_CLEANUP_CRON=0 * * * * # cron文字列、期限切れ認証データ削除schedule
PROJECT_NAME=org-auth # 文字列、D1 database名とR2 bucket名のprefix
ACCOUNT_WORKER_SERVICE_NAME=org-auth-account # 文字列、account Worker service名

# account Worker
AUTH_APPS=[{"app_id":"service","callback_url":"https://app.example.com/_auth/callback","session_verify_secret":"replace-with-app-session-secret"}] # JSON配列文字列、認可するapp一覧。複数appは配列へ追加します。各session_verify_secretは該当app側のAPP_SESSION_HMAC_SECRETと同じ値にします

DISCORD_CLIENT_ID= # 文字列、Discord OAuth2 client ID
DISCORD_CLIENT_SECRET= # 文字列、Discord OAuth2 client secret
DISCORD_PUBLIC_KEY= # 文字列、Discord Interaction署名検証用public key
DISCORD_GUILD_IDS= # カンマ区切り文字列、認証対象DiscordサーバーID
DISCORD_BOT_TOKEN= # 文字列、OTP DM送信用Bot token

SESSION_HMAC_SECRET= # 文字列、accountセッション署名secret
CSRF_KID=2026-04 # 文字列、CSRF署名key ID
CSRF_HMAC_SECRET= # 文字列、CSRF署名secret
OTP_HMAC_SECRET= # 文字列、OTPハッシュ用secret
