{
  "name": "link-auth",
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/crypto.d.ts",
    "dist/crypto.js",
    "dist/encoding.d.ts",
    "dist/encoding.js",
    "dist/index.d.ts",
    "dist/index.js",
    "dist/session.d.ts",
    "dist/session.js"
  ],
  "types": "./dist/index.d.ts",
  "scripts": {
    "build:lib": "rm -rf dist && tsc -p tsconfig.lib.json",
    "check": "biome check .",
    "prepack": "pnpm build:lib",
    "test": "pnpm test:workers",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:workers": "pnpm build:lib && vitest run --config vitest.workers.config.ts",
    "typecheck": "pnpm build:lib && tsc --noEmit",
    "format": "biome check --write .",
    "build:styles": "tailwindcss -i workers/account/src/views/styles.css -o workers/account/src/views/lib/stylesGenerated.css --minify && tsx local/writeStyleModule.ts",
    "build:client": "tsx local/writeAccountClientModule.ts",
    "build:workers": "pnpm build:lib && pnpm build:styles && pnpm build:client && tsc --noEmit -p workers/tsconfig.json",
    "dev": "pnpm dev:env && pnpm build:lib && pnpm build:styles && pnpm build:client && concurrently --kill-others-on-fail --names assets,account,service --prefix-colors blue,green,magenta \"pnpm dev:assets\" \"pnpm dev:account\" \"pnpm dev:service\"",
    "dev:assets": "tsx local/watchDevAssets.ts",
    "dev:env": "tsx local/syncDevEnv.ts",
    "prod:env": "tsx local/syncDevEnv.ts --env production",
    "dev:seed": "tsx local/seedD1.ts",
    "d1:migrations:apply": "wrangler d1 migrations apply org-auth --remote --config workers/account/wrangler.toml",
    "d1:migrations:list": "wrangler d1 migrations list org-auth --remote --config workers/account/wrangler.toml",
    "dev:account": "wrangler dev --config workers/account/wrangler.toml --local --port 8787 --inspector-port 0 --live-reload",
    "dev:service": "wrangler dev --config workers/app/wrangler.toml --local --port 8789 --inspector-port 0 --live-reload",
    "knip": "knip",
    "tf:fmt": "terraform -chdir=infra fmt",
    "tf:fmt:check": "terraform -chdir=infra fmt -check",
    "tf:init": "terraform -chdir=infra init",
    "tf:validate": "terraform -chdir=infra validate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@cloudflare/vitest-pool-workers": "^0.15.2",
    "@cloudflare/workers-types": "^4.20260503.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/cli": "^4.2.4",
    "@types/node": "^22.15.3",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "esbuild": "^0.27.3",
    "knip": "^6.7.0",
    "lefthook": "^2.1.6",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.13.0"
  },
  "dependencies": {
    "@tabler/icons": "3.41.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cropperjs": "1.6.2",
    "tailwind-merge": "^3.5.0",
    "tweetnacl": "^1.0.3"
  }
}
