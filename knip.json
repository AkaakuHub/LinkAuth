{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "local/**/*.{ts,tsx}",
    "src/**/*.{ts,tsx}",
    "workers/*/src/**/*.{ts,tsx}"
  ],
  "project": [
    "local/**/*.{ts,tsx}",
    "src/**/*.{ts,tsx}",
    "tests/**/*.{ts,tsx}",
    "workers/*/src/**/*.{ts,tsx}"
  ],
  "ignoreDependencies": ["cloudflare", "lefthook", "tailwindcss"],
  "ignoreBinaries": ["terraform"]
}
